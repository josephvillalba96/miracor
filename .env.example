# ============================================================
#  WOMPI — Variables de entorno
#  Copia este archivo como `.env` y rellena con tus llaves.
#  Obtén tus llaves en: https://comercios.wompi.co → Desarrolladores
# ============================================================

# ----------------------------------------------------------
# LLAVE PÚBLICA DE COMERCIO
# Empieza con "pub_test_" en Sandbox y "pub_prod_" en Producción.
# Es segura para exponerse en el frontend.
# ----------------------------------------------------------
VITE_WOMPI_PUBLIC_KEY=pub_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ----------------------------------------------------------
# SECRETO DE INTEGRIDAD
# ⚠️  ADVERTENCIA DE SEGURIDAD:
# Este secreto se usa para generar la firma SHA256 de integridad.
# En producción NUNCA debe estar en el frontend.
# Muévelo a un backend (Node.js, PHP, etc.) antes de ir a producción.
# Por ahora se usa solo para desarrollo/sandbox.
# Empieza con "test_integrity_" o "prod_integrity_"
# ----------------------------------------------------------
VITE_WOMPI_INTEGRITY_SECRET=test_integrity_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ----------------------------------------------------------
# URL DE REDIRECCIÓN TRAS EL PAGO
# Wompi redirigirá al usuario aquí con ?id=TRANSACTION_ID
# Ejemplo desarrollo: http://localhost:5173/pagos/resultado
# Ejemplo producción: https://miracor.com.co/pagos/resultado
# ----------------------------------------------------------
VITE_WOMPI_REDIRECT_URL=http://localhost:5173/pagos/resultado

# ----------------------------------------------------------
# ENTORNO (sandbox | production)
# Usa "sandbox" durante pruebas y "production" en producción.
# ----------------------------------------------------------
VITE_WOMPI_ENV=sandbox
